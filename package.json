{
  "name": "docent",
  "description": "Captures demonstrated workflows as structured data — not code.",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:schemas": "node scripts/build-schemas.js",
    "version:schemas": "node scripts/auto-version-schemas.js",
    "version:schemas:check": "node scripts/auto-version-schemas.js --check",
    "sufficiency:check": "node scripts/sufficiency-lint.js packages/shared/tests/fixtures corpus/sessions --baseline packages/shared/tests/fixtures/sufficiency-baseline.json",
    "corpus:produce:extension": "cd packages/extension/tests/e2e && npx playwright test --config playwright.corpus.config.js",
    "corpus:check": "node scripts/corpus-compare.js --platform extension --baseline corpus/known-diffs.extension.json --lint",
    "vectors:produce:extension": "cd packages/extension/tests/e2e && npx playwright test --config playwright.vectors.config.js",
    "vectors:check": "npm run vectors:produce:extension && node --test packages/shared/tests/unit/conformance-vectors.test.js",
    "version:next": "node scripts/next-release-version.js",
    "check:no-release-outputs": "node scripts/check-no-release-outputs.js",
    "check:pr-title": "node scripts/check-pr-title.js",
    "check:action-pins": "node scripts/check-action-pins.js",
    "check:licenses": "node scripts/check-licenses-npm.js",
    "sync-shared": "node scripts/sync-shared.js",
    "build:desktop-dist": "node scripts/build-desktop-dist.js",
    "dev:desktop": "npm run sync-shared && npm run build:desktop-dist && echo 'Run cargo tauri dev from packages/desktop/src-tauri/'",
    "dev:extension": "npm run sync-shared && echo 'Load packages/extension/ in Chrome'",
    "test:extension": "npm run sync-shared && cd packages/extension && npm test",
    "test:desktop": "node --test packages/desktop/tests/unit/*.test.js",
    "test:desktop:rust": "cargo test --manifest-path packages/desktop/src-tauri/Cargo.toml",
    "test:shared": "node --test packages/shared/tests/unit/*.test.js",
    "test:unit": "node --test packages/shared/tests/unit/*.test.js packages/desktop/tests/unit/*.test.js packages/extension/tests/unit/*.test.js",
    "test:integration": "cd packages/desktop/tests/integration && npm test",
    "test:e2e": "cd packages/extension/tests/e2e && npm test",
    "test:mutation": "npx stryker run",
    "test:mutation:extension": "npx stryker run stryker.extension.mjs",
    "test:mutation:desktop": "npx stryker run stryker.desktop.mjs",
    "test:shared:coverage": "c8 --reporter=text --reporter=lcov node --test packages/shared/tests/unit/*.test.js",
    "test:desktop:coverage": "c8 --reporter=text --reporter=lcov node --test packages/desktop/tests/unit/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test packages/shared/tests/unit/*.test.js packages/desktop/tests/unit/*.test.js",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:md && npm run lint:links && npm run lint:reachability && npm run lint:area-map && npm run lint:clause-registry && npm run lint:clause-governance && npm run lint:ci-filter && npm run lint:format",
    "lint:js": "eslint packages/shared/ packages/extension/sidepanel/ packages/extension/content/ packages/extension/background/ packages/desktop/src/ scripts/ reference-implementations/ corpus/",
    "lint:css": "stylelint \"packages/shared/views/**/*.css\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:links": "remark . --quiet --frail --ignore-path .gitignore",
    "lint:reachability": "node scripts/check-doc-reachability.js",
    "lint:area-map": "node scripts/check-area-map.js",
    "lint:clause-registry": "node scripts/check-clause-registry.js",
    "lint:clause-governance": "node scripts/check-clause-governance.js",
    "lint:ci-filter": "node scripts/check-ci-filter.js",
    "lint:format": "prettier --check .",
    "format": "prettier --write .",
    "update-version-table": "node scripts/update-version-table.js",
    "bump:schema": "node scripts/bump-schema.js",
    "prepublish": "npm run sync-shared",
    "postinstall": "lefthook install",
    "corpus:assemble:desktop": "node scripts/corpus-assemble-desktop.js",
    "corpus:check:desktop": "node scripts/corpus-compare.js --platform desktop-windows --baseline corpus/known-diffs.desktop-windows.json --lint",
    "vectors:produce:desktop": "cargo test --manifest-path packages/desktop/src-tauri/Cargo.toml --test corpus_capture v_vector_fixture -- --test-threads=1",
    "vectors:assemble:desktop": "node scripts/corpus-assemble-desktop-vectors.js",
    "vectors:check:desktop": "npm run vectors:produce:desktop && npm run vectors:assemble:desktop && node --test packages/shared/tests/unit/conformance-vectors.test.js"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@tauri-apps/api": "^2.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "js-yaml": "^4.2.0",
    "lefthook": "^2.1.10",
    "license-checker-rseidelsohn": "5.0.1",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.5",
    "remark-cli": "^12.0.1",
    "remark-parse": "^11.0.0",
    "remark-validate-links": "^13.1.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
