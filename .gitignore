# Dependencies
node_modules/

# Rust build artifacts
packages/desktop/src-tauri/target/

# Tauri auto-generated files (regenerated on build)
packages/desktop/src-tauri/gen/

# Synced shared code (build artifact — run `npm run sync-shared` to regenerate)
packages/*/shared/

# Generated validators (build artifact — Ajv standalone, produced by
# scripts/build-validators.js via sync-shared)
packages/shared/generated/

# Generated HTML (assembled from shell + shared views by sync-shared)
packages/extension/sidepanel/index.html
packages/desktop/src/index.html

# Desktop frontend dist (assembled by scripts/build-desktop-dist.js)
packages/desktop/dist/

# Session exports (contain recorded user interactions — never commit these)
*.docent.json
# ...except the frozen backward-compat test fixtures (#87), which are
# intentionally committed regression anchors, not real user exports.
!packages/shared/tests/fixtures/**/*.docent.json

# CLA signatures (managed by cla-assistant bot, stored in signatures/ branch)
signatures/

# OS
.DS_Store
Thumbs.db

# Test artifacts
test-results/
playwright-report/
coverage/
coverage*.lcov
.c8_output/
reports/
.stryker-tmp/

# Lefthook local config
lefthook-local.yml

# Editor
.vscode/
.idea/
*.swp
.kiro/
.cursor/
.windsurf/
.copilot/
.claude/
CLAUDE.md
CLAUDE.local.md

# Environment
.env
.env.local

# Security backlog (private — not for public disclosure)
SECURITY_BACKLOG.md
