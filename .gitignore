# Dependencies
node_modules/

# Rust build artifacts
packages/desktop/src-tauri/target/

# Tauri auto-generated files (regenerated on build)
packages/desktop/src-tauri/gen/

# Synced shared code (build artifact — run `npm run sync-shared` to regenerate)
packages/*/shared/

# Generated validators (build artifact — Ajv standalone, produced by
# scripts/build-validators.js via sync-shared)
packages/shared/generated/

# NOTE: the assembled index.html for the extension side panel and the desktop
# frontend (each built from its index.shell.html + shared/views/views.html by
# sync-shared) are DELIBERATELY COMMITTED — like schemas/dist/ — and CI verifies
# they match sync-shared output ("Verify sync-shared output is fresh"). They are
# intentionally NOT ignored here: an ignore rule on already-tracked files is inert
# and would only mask staleness. Edit the shells/views and re-run sync-shared.

# Desktop frontend dist (assembled by scripts/build-desktop-dist.js)
packages/desktop/dist/

# Session exports (contain recorded user interactions — never commit these)
*.docent.json
# ...except the frozen backward-compat test fixtures (#87), which are
# intentionally committed regression anchors, not real user exports.
!packages/shared/tests/fixtures/**/*.docent.json
# ...and the capture corpus's truth files: authored expected envelopes for
# scripted sessions on committed pages, not real user exports. The corpus's
# per-run produced output stays ignored via corpus/out/ below.
!corpus/sessions/**/*.docent.json

# CLA signatures (managed by cla-assistant bot, stored in signatures/ branch)
signatures/

# OS
.DS_Store
Thumbs.db

# Test artifacts
test-results/
playwright-report/
coverage/
coverage*.lcov
.c8_output/
reports/
.stryker-tmp/

# Lefthook local config
lefthook-local.yml

# Editor
.vscode/
.idea/
*.swp
.kiro/
.cursor/
.windsurf/
.copilot/
.claude/
CLAUDE.md
CLAUDE.local.md

# Environment
.env
.env.local

# Security backlog (private — not for public disclosure)
SECURITY_BACKLOG.md
corpus/out/
