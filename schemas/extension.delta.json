{
  "$id": "https://github.com/Arsarneq/docent/blob/main/schemas/dist/extension.schema.json",
  "title": "Docent Extension Schema",
  "platform": "extension",
  "version": "3.0.0",
  "description": "Schema for .docent.json files produced by the Docent Chrome extension.",
  "actionContextProperty": {
    "name": "frame_src",
    "schema": {
      "$ref": "#/$defs/frame_src"
    }
  },
  "$defs": {
    "capture_mode": {
      "type": "string",
      "const": "dom",
      "description": "How the action was captured. Always 'dom' for the browser extension."
    },
    "frame_src": {
      "type": ["string", "null"],
      "description": "Iframe URL if the action occurred inside an iframe. Null for the top frame."
    },
    "action_navigate": {
      "properties": {
        "type": {
          "const": "navigate"
        },
        "nav_type": {
          "type": "string",
          "enum": [
            "link",
            "typed",
            "reload",
            "back_forward",
            "spa",
            "auto_bookmark",
            "generated",
            "start_page",
            "form_submit",
            "keyword"
          ]
        },
        "url": {
          "type": "string",
          "description": "The destination URL. Values of sensitive query parameters are masked at capture; the masked parameter names (matched case-insensitively) are exactly: token, access_token, id_token, refresh_token, auth, authorization, api_key, apikey, key, secret, client_secret, password, pwd, session, sessionid, sid, otp, code, signature, sig, sso. Other parameters are preserved."
        },
        "context_id": {
          "$ref": "#/$defs/context_id"
        },
        "capture_mode": {
          "$ref": "#/$defs/capture_mode"
        }
      },
      "required": ["type", "timestamp", "nav_type", "url", "context_id", "capture_mode"]
    },
    "action_file_upload": {
      "properties": {
        "type": {
          "const": "file_upload"
        },
        "element": {
          "$ref": "#/$defs/element"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "size", "mime"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              },
              "mime": {
                "type": "string"
              }
            }
          }
        },
        "context_id": {
          "$ref": "#/$defs/context_id"
        },
        "capture_mode": {
          "$ref": "#/$defs/capture_mode"
        }
      },
      "required": ["type", "timestamp", "element", "files", "context_id", "capture_mode"]
    },
    "action": {
      "type": "object",
      "required": ["type", "timestamp"],
      "properties": {
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix milliseconds."
        }
      },
      "oneOf": [
        {
          "$ref": "#/$defs/action_navigate"
        },
        {
          "$ref": "#/$defs/action_click"
        },
        {
          "$ref": "#/$defs/action_right_click"
        },
        {
          "$ref": "#/$defs/action_type"
        },
        {
          "$ref": "#/$defs/action_select"
        },
        {
          "$ref": "#/$defs/action_key"
        },
        {
          "$ref": "#/$defs/action_focus"
        },
        {
          "$ref": "#/$defs/action_file_upload"
        },
        {
          "$ref": "#/$defs/action_drag_start"
        },
        {
          "$ref": "#/$defs/action_drop"
        },
        {
          "$ref": "#/$defs/action_scroll"
        },
        {
          "$ref": "#/$defs/action_context_switch"
        },
        {
          "$ref": "#/$defs/action_context_open"
        },
        {
          "$ref": "#/$defs/action_context_close"
        }
      ]
    },
    "locator": {
      "type": "object",
      "required": ["strategy"],
      "properties": {
        "strategy": {
          "type": "string",
          "description": "Locator strategy identifier — selects which entry shape applies."
        }
      },
      "description": "A locator candidate for the acted-on element. Match statistics (match_count / match_index) are measured against the capturing frame's document root (the same boundary selector derivation stops at), in document order, using standard non-piercing matching (shadow roots are not descended into), synchronously at the moment the acted-on element is described for capture: for immediately-captured actions that is inside the capture handler, before the action's effects run; for deliberately debounced or deferred captures (Tab-correlated focus, scroll settle, contenteditable typing pauses) it is when the capture commits, against the then-current document.",
      "oneOf": [
        {
          "$ref": "#/$defs/locator_id"
        },
        {
          "$ref": "#/$defs/locator_test_id"
        },
        {
          "$ref": "#/$defs/locator_name"
        },
        {
          "$ref": "#/$defs/locator_tag_name"
        },
        {
          "$ref": "#/$defs/locator_role_name"
        },
        {
          "$ref": "#/$defs/locator_label"
        },
        {
          "$ref": "#/$defs/locator_text"
        },
        {
          "$ref": "#/$defs/locator_placeholder"
        },
        {
          "$ref": "#/$defs/locator_title"
        },
        {
          "$ref": "#/$defs/locator_alt_text"
        },
        {
          "$ref": "#/$defs/locator_css"
        }
      ]
    },
    "locator_id": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "id"
        },
        "value": {
          "type": "string",
          "description": "Value of the element's id attribute."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_test_id": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "test_id"
        },
        "attribute": {
          "type": "string",
          "description": "The attribute that carried the value, e.g. \"data-testid\"."
        },
        "value": {
          "type": "string",
          "description": "The test attribute's value."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "attribute", "value"],
      "additionalProperties": false
    },
    "locator_name": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "name"
        },
        "value": {
          "type": "string",
          "description": "Value of the element's name attribute."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_tag_name": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "tag_name"
        },
        "value": {
          "type": "string",
          "description": "The element's tag name, lower-cased for HTML elements and case-preserved for foreign (e.g. SVG) elements."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_role_name": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "role_name"
        },
        "role": {
          "type": "string",
          "description": "The element's ARIA role — the explicit role attribute value, or the role implied by the element."
        },
        "name": {
          "type": "string",
          "description": "The element's computed accessible name."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "role", "name"],
      "additionalProperties": false
    },
    "locator_label": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "label"
        },
        "mechanism": {
          "type": "string",
          "enum": ["for", "wrapped", "aria-labelledby"],
          "description": "How the label is associated with the element: \"for\" (label for-attribute), \"wrapped\" (element nested inside the label), or \"aria-labelledby\" (referenced by id)."
        },
        "value": {
          "type": "string",
          "description": "The label's visible text."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "mechanism", "value"],
      "additionalProperties": false
    },
    "locator_text": {
      "x-value-derived": true,
      "properties": {
        "strategy": {
          "const": "text"
        },
        "value": {
          "type": "string",
          "description": "The element's rendered (visible) text, whitespace-normalized (leading/trailing whitespace removed, internal runs collapsed to single spaces). The candidate is omitted when the element has no rendered text (a form control's value is not rendered text) or when the normalized text exceeds 100 characters — a truncated value would not be an exact observed value. Match statistics count the same-tag-name elements in the stated scope whose rendered text, under this same normalization, equals this value; the pair is absent when that set was too large to measure cheaply."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_placeholder": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "placeholder"
        },
        "value": {
          "type": "string",
          "description": "Value of the element's placeholder attribute."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_title": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "title"
        },
        "value": {
          "type": "string",
          "description": "Value of the element's title attribute."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_alt_text": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "alt_text"
        },
        "value": {
          "type": "string",
          "description": "Value of the element's alt attribute."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    },
    "locator_css": {
      "x-value-derived": false,
      "properties": {
        "strategy": {
          "const": "css"
        },
        "value": {
          "type": "string",
          "description": "A CSS selector derived for the element from observed attributes and structure."
        },
        "match_count": {
          "$ref": "#/$defs/locator_match_count"
        },
        "match_index": {
          "$ref": "#/$defs/locator_match_index"
        },
        "masked": {
          "$ref": "#/$defs/locator_masked"
        }
      },
      "required": ["strategy", "value"],
      "additionalProperties": false
    }
  }
}
