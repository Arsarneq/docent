{
  "description": "Desktop-family shared layer for all Docent desktop surfaces (Windows, and Linux when it lands). Composed on top of the platform-agnostic shared.schema.json and beneath a per-surface leaf delta (e.g. desktop-windows.delta.json) by scripts/build-schemas.js. Holds the definitions common to every desktop surface: native capture modes, window geometry, and desktop-only action types. Not used directly for validation.",
  "actionContextProperty": {
    "name": "window_rect",
    "schema": {
      "$ref": "#/$defs/window_rect_or_null"
    }
  },
  "$defs": {
    "capture_mode": {
      "type": "string",
      "enum": ["accessibility", "coordinate"],
      "description": "How the action was captured. 'accessibility' for native UI elements, 'coordinate' for fallback coordinate-based capture."
    },
    "window_rect": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer",
          "description": "Window X position on screen in logical pixels."
        },
        "y": {
          "type": "integer",
          "description": "Window Y position on screen in logical pixels."
        },
        "width": {
          "type": "integer",
          "description": "Window width in logical pixels."
        },
        "height": {
          "type": "integer",
          "description": "Window height in logical pixels."
        }
      },
      "description": "Window position and size at capture time, resolved from the action window handle regardless of capture mode."
    },
    "window_rect_or_null": {
      "oneOf": [
        {
          "$ref": "#/$defs/window_rect"
        },
        {
          "type": "null"
        }
      ],
      "description": "Window rectangle or null: resolved from the action window handle regardless of capture mode; null when no window handle was resolvable."
    },
    "action_file_dialog": {
      "properties": {
        "type": {
          "const": "file_dialog"
        },
        "dialog_type": {
          "type": "string",
          "enum": ["open", "save", "save_as"]
        },
        "file_path": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "description": "The application that opened the file dialog (exe path)."
        },
        "context_id": {
          "$ref": "#/$defs/context_id"
        },
        "capture_mode": {
          "$ref": "#/$defs/capture_mode"
        }
      },
      "required": [
        "type",
        "timestamp",
        "dialog_type",
        "file_path",
        "source",
        "context_id",
        "capture_mode"
      ]
    },
    "action": {
      "type": "object",
      "required": ["type", "timestamp"],
      "properties": {
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix milliseconds."
        }
      },
      "oneOf": [
        {
          "$ref": "#/$defs/action_click"
        },
        {
          "$ref": "#/$defs/action_right_click"
        },
        {
          "$ref": "#/$defs/action_type"
        },
        {
          "$ref": "#/$defs/action_select"
        },
        {
          "$ref": "#/$defs/action_key"
        },
        {
          "$ref": "#/$defs/action_focus"
        },
        {
          "$ref": "#/$defs/action_drag_start"
        },
        {
          "$ref": "#/$defs/action_drop"
        },
        {
          "$ref": "#/$defs/action_scroll"
        },
        {
          "$ref": "#/$defs/action_context_switch"
        },
        {
          "$ref": "#/$defs/action_context_open"
        },
        {
          "$ref": "#/$defs/action_context_close"
        },
        {
          "$ref": "#/$defs/action_file_dialog"
        }
      ]
    }
  }
}
